# ──────────────────────────────────────────────────────────────────────────
# Slack × Elastic 데모 — 환경변수 예시
# 이 파일을 .env 로 복사한 뒤 값을 채우세요:  cp .env.example .env
# .env 는 절대 git 에 커밋하지 마세요 (.gitignore 에 이미 포함).
# ──────────────────────────────────────────────────────────────────────────

# ── Slack ──────────────────────────────────────────────────────────────────
# Bot User OAuth Token (Install to Workspace 후 발급). 형식: xoxb-...
SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-Level Token (connections:write scope, Socket Mode 용). 형식: xapp-...
SLACK_APP_TOKEN=xapp-your-app-token

# ── Kibana ───────────────────────────────────────────────────────────────────
# Kibana 베이스 URL (끝 슬래시 없이). 예) https://my-deploy.kb.ap-northeast-2.aws.elastic-cloud.com
KIBANA_URL=https://your-kibana.example.com
# Kibana API Key 의 base64 'encoded' 값 (POST /_security/api_key 응답의 encoded 필드)
KIBANA_API_KEY=base64-encoded-api-key
# Kibana Space (기본 space 면 default, 그대로 두면 됨)
KIBANA_SPACE=default

# ── Agent Builder ───────────────────────────────────────────────────────────
# @멘션 시 대화할 기본 agent id. Kibana > Agent Builder 에서 만든 agent 의 id.
DEFAULT_AGENT_ID=elastic-ai-agent

# ── 디버그(개발용, 선택) ──────────────────────────────────────────────────────
# 값이 있으면 켜짐. run.sh --debug 로도 켤 수 있음.
# DEBUG_SSE=1   # Agent Builder SSE 이벤트를 콘솔에 출력
# DEBUG_WF=1    # 워크플로우 실행/로그 JSON 을 콘솔에 출력
